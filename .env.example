# Token secreto para proteger /api/links e o painel /admin
ADMIN_TOKEN=troque-por-um-token-forte

# Chave da API pública (POST/GET /api/v1/redirects) — Authorization: Bearer …
REDIRECT_API_KEY=troque-por-uma-chave-forte

# URL pública do serviço (usada em redirect_url na resposta da API)
# Produção: https://redirect.clubepromos.com.br
# Local:    http://localhost:5222
BASE_URL=https://redirect.clubepromos.com.br

# Hosts Shopee (apenas para auto-preencher título/subIds). Destino do redirect
# aceita qualquer https público — landings, lojas, etc.
ALLOWED_HOSTS=shopee.com.br,s.shopee.com.br

# Caminho opcional do arquivo SQLite (padrão: ./data/redirect.db)
# DB_PATH=./data/redirect.db

# Opcional: API de Afiliados Shopee (para buscar nome do produto)
# SHOPEE_AFFILIATE_APP_ID=
# SHOPEE_AFFILIATE_SECRET=
