# Token secreto para proteger /api/links
ADMIN_TOKEN=troque-por-um-token-forte

# URL pública do serviço (usada ao criar links)
BASE_URL=http://localhost:5222

# Hosts Shopee permitidos (separados por vírgula)
ALLOWED_HOSTS=shopee.com.br,s.shopee.com.br

# Caminho opcional do arquivo SQLite (padrão: ./data/redirect.db)
# DB_PATH=./data/redirect.db

# Opcional: API de Afiliados Shopee (para buscar nome do produto)
# SHOPEE_AFFILIATE_APP_ID=
# SHOPEE_AFFILIATE_SECRET=
